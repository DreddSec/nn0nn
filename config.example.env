# ─────────────────────────────────────────────────────────────────────────────
# nn0nn — ejemplo de configuración de API keys
# ─────────────────────────────────────────────────────────────────────────────
#
# INSTRUCCIONES:
# 1. Copia este fichero: cp config.example.env .env
# 2. Rellena las keys que tengas
# 3. Las keys vacías desactivan ese módulo automáticamente
#
# IMPORTANTE: El fichero .env está en .gitignore.
#             Nunca subas tus keys reales a GitHub.
# ─────────────────────────────────────────────────────────────────────────────

# Shodan — https://account.shodan.io
# Necesaria para el módulo --shodan: puertos, servicios, banners por subdominio
SHODAN_API_KEY=

# URLScan.io — https://urlscan.io/user/profile
# Necesaria para el módulo --urlscan: screenshots, requests, tecnologías
URLSCAN_API_KEY=
